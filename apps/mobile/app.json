{
  "expo": {
    "name": "SHA NADC EMT",
    "slug": "sha-nadc-emt",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "shanadc",
    "splash": {
      "backgroundColor": "#0B0F14",
      "resizeMode": "contain"
    },
    "ios": {
      "bundleIdentifier": "ke.go.sha.nadc.emt",
      "supportsTablet": true,
      "userInterfaceStyle": "dark",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SHA NADC reports your ambulance position to the dispatch centre while you are on a call."
      }
    },
    "android": {
      "package": "ke.go.sha.nadc.emt",
      "adaptiveIcon": {
        "backgroundColor": "#0B0F14"
      },
      "userInterfaceStyle": "dark",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "SHA NADC reports your ambulance position to the dispatch centre while you are on a call."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "supabaseUrl": null,
      "supabaseAnonKey": null
    }
  }
}
