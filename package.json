{
  "name": "sha-nadc-platform",
  "version": "0.1.0",
  "private": true,
  "description": "SHA NADC v2 — production-grade National Ambulance Dispatch Centre platform.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.2.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo clean && rm -rf node_modules",
    "check-env": "tsx scripts/check-env.ts",
    "seed": "tsx scripts/seed-db.ts"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "@types/node": "^22.10.0",
    "dotenv": "^17.4.2",
    "prettier": "^3.4.0",
    "tsx": "^4.22.3",
    "turbo": "^2.5.0",
    "typescript": "^5.7.0"
  }
}
